# Safety boundaries
ENABLE_LIVE_TRADING=false
NO_VIDEO_CAPTURE=true

# Kalshi market data
KALSHI_ENV=production
KALSHI_BASE_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://external-api-ws.kalshi.com/trade-api/ws/v2
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# MLB Stats API
MLB_BASE_URL=https://statsapi.mlb.com/api/v1

# The Odds API
ODDS_API_KEY=
ODDS_BASE_URL=https://api.the-odds-api.com/v4
ODDS_REGION=us

# Storage
DUCKDB_PATH=data/kalshi_mlb.duckdb
PARQUET_DIR=data/parquet
REPORTS_DIR=data/reports

# Execution research defaults
SAFETY_MARGIN=0.03
SLIPPAGE_BUFFER=0.01
MAX_SPREAD=0.08
MAX_CONTRACTS_PER_TRADE=5
MAX_POSITION_PER_MARKET=20
MAX_OPEN_MARKETS=3
MAX_DAILY_LOSS_USD=25
MIN_BOOK_DEPTH=5
MAX_DATA_STALENESS_MS=3000
MAX_MODEL_UNCERTAINTY_WIDTH=0.15
